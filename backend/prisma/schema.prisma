// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Student {
  id            Int                   @id @default(autoincrement())
  name          String
  email         String                @unique
  password      String
  studentId     String                @unique
  department    String
  year          Int
  profileImage  String?
  createdAt     DateTime              @default(now())
  registrations StudentEventRegistration[]
  presidentApplications PresidentApplication[]
  notifications StudentNotification[]
}

model StudentEventRegistration {
  id         Int      @id @default(autoincrement())
  studentId  Int
  eventId    Int
  registeredAt DateTime @default(now())
  student    Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  event      Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([studentId, eventId])
}

enum Role {
  STUDENT
  EVENT_ORGANIZER
  SYSTEM_ADMIN
  CLUB_PRESIDENT
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      Role
  profileImage String?
  createdAt DateTime @default(now())

  // relations for logistics module
  assets             Asset[]          @relation("AssetOwner")
  approvedBookings   AssetBooking[]   @relation("AssetBookingApprovedBy")
  requestedBookings  AssetBooking[]   @relation("AssetBookingRequester")
  approvedApplications PresidentApplication[]
  notifications      UserNotification[]
}

model Event {
  id              Int                   @id @default(autoincrement())
  title           String
  description     String
  date            DateTime
  category        String
  location        String
  image           String
  registeredCount Int                   @default(0)
  createdAt       DateTime              @default(now())
  registrations   StudentEventRegistration[]
}

// Logistics module models
model Asset {
  id          Int          @id @default(autoincrement())
  name        String
  description String?
  ownerId     Int
  owner       User         @relation(name: "AssetOwner", fields: [ownerId], references: [id])
  status      AssetStatus  @default(AVAILABLE)
  bookings    AssetBooking[]
  createdAt   DateTime     @default(now())
}

model AssetBooking {
  id           Int           @id @default(autoincrement())
  assetId      Int
  requesterId  Int
  startDate    DateTime
  endDate      DateTime
  status       BookingStatus @default(PENDING)
  damageReport String?
  penalty      Float?
  approvedById Int?
  approvedBy   User?         @relation(name: "AssetBookingApprovedBy", fields: [approvedById], references: [id])

  asset        Asset         @relation(fields: [assetId], references: [id], onDelete: Cascade)
  requester    User          @relation(name: "AssetBookingRequester", fields: [requesterId], references: [id])

  @@index([assetId])
  @@index([requesterId])
}

// president applications
model PresidentApplication {
  id                    Int                @id @default(autoincrement())
  studentId             Int
  student               Student            @relation(fields: [studentId], references: [id], onDelete: Cascade)
  presidentName         String             // The name to use for president account
  candidateId           String             // President ID/candidate ID
  clubOrFacultyType     String             // "CLUB" or "FACULTY"
  clubOrFacultyName     String             // Name of club or faculty
  currentQualification  String             // Current qualification/position
  email                 String             // email for president account
  status                ApplicationStatus  @default(PENDING)
  rejectionReason       String?            // Reason for rejection if rejected
  appliedAt             DateTime           @default(now())
  approvedRejectAt      DateTime?          // When it was approved/rejected
  approvedById          Int?
  approvedBy            User?              @relation(fields: [approvedById], references: [id], onDelete: SetNull)
}

// Student notifications/alerts
model StudentNotification {
  id        Int       @id @default(autoincrement())
  studentId Int
  student   Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  type      String    // "PRESIDENT_APPROVED", "PRESIDENT_REJECTED", "PASSWORD_ALERT", etc.
  title     String
  message   String
  data      String?   // JSON string for additional data (e.g., password)
  isRead    Boolean   @default(false)
  createdAt DateTime  @default(now())

  @@index([studentId])
  @@index([createdAt])
}

// User notifications (for admin/president accounts)
model UserNotification {
  id        Int       @id @default(autoincrement())
  userId    Int
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String    // "APPLICATION_CREATED", "NEW_REQUEST", etc.
  title     String
  message   String
  data      String?   // JSON string for additional data
  isRead    Boolean   @default(false)
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([createdAt])
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AssetStatus {
  AVAILABLE
  UNAVAILABLE
}

enum BookingStatus {
  PENDING
  APPROVED
  REJECTED
  CHECKED_OUT
  RETURNED
  DAMAGED
}
