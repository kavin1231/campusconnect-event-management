// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  output          = "../generated/prisma"
  engineType      = "library"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model Student {
  id            Int                   @id @default(autoincrement())
  name          String
  email         String                @unique
  password      String
  studentId     String                @unique
  department    String
  year          Int
  profileImage  String?
  createdAt     DateTime              @default(now())
  registrations StudentEventRegistration[]
  presidentApplications PresidentApplication[]
  notifications StudentNotification[]
  eventReviews  EventReview[]

  @@map("Student")
}

model StudentEventRegistration {
  id         Int      @id @default(autoincrement())
  studentId  Int
  eventId    Int
  registeredAt DateTime @default(now())
  student    Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  event      Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([studentId, eventId])
  @@map("StudentRegistration")
}

enum Role {
  STUDENT
  SYSTEM_ADMIN
  CLUB_PRESIDENT
  EVENT_ORGANIZER
}

enum AssetStatus {
  AVAILABLE
  UNAVAILABLE
  MAINTENANCE
  DAMAGED
  ARCHIVED
}

enum BookingStatus {
  PENDING
  APPROVED
  REJECTED
  CHECKED_OUT
  RETURNED
  CANCELLED
  DAMAGED
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id               Int      @id @default(autoincrement())
  name             String
  email            String   @unique
  password         String
  role             Role
  profileImage     String?
  createdAt        DateTime @default(now())
  
  // relationships for logistics module
  approvedBookings AssetBooking[]   @relation("AssetBookingApprovedBy")
  requestedBookings AssetBooking[]  @relation("AssetBookingRequester")
  approvedReturns  AssetBooking[]   @relation("ReturnApprovedBy")
  
  approvedApplications PresidentApplication[]
  notifications    UserNotification[]

  @@map("User")
}

model Event {
  id              Int                   @id @default(autoincrement())
  title           String
  description     String
  date            DateTime
  category        String
  location        String
  image           String
  registeredCount Int                   @default(0)
  createdAt       DateTime              @default(now())
  registrations   StudentEventRegistration[]
  reviews         EventReview[]

  @@map("Event")
}

// ========== ENHANCED LOGISTICS MODELS ==========
model Asset {
  id               Int                 @id @default(autoincrement())
  name             String
  description      String?
  ownerId          Int
  status           AssetStatus         @default(AVAILABLE)
  createdAt        DateTime            @default(now())
  
  // Relationships
  bookings         AssetBooking[]
  
  @@map("Asset")
}

model AssetBooking {
  id                  Int                @id @default(autoincrement())
  assetId             Int
  asset               Asset              @relation(fields: [assetId], references: [id], onDelete: Cascade)
  
  // User who requested
  requesterId         Int
  requester           User               @relation(name: "AssetBookingRequester", fields: [requesterId], references: [id])
  
  // Booking details
  startDate           DateTime
  endDate             DateTime
  
  // Approval
  status              BookingStatus      @default(PENDING)
  approvedById        Int?
  approvedBy          User?              @relation(name: "AssetBookingApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)
  approvedAt          DateTime?
  
  // Return tracking
  approvedReturnBy    Int?
  approvedReturnUser  User?              @relation(name: "ReturnApprovedBy", fields: [approvedReturnBy], references: [id], onDelete: SetNull)
  
  // Damage & penalties
  penalty             Float?             @default(0)
  
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  @@index([assetId])
  @@index([requesterId])
  @@index([status])
  @@map("AssetBooking")
}

// president applications
model PresidentApplication {
  id                    Int                @id @default(autoincrement())
  studentId             Int
  student               Student            @relation(fields: [studentId], references: [id], onDelete: Cascade)
  presidentName         String             // The name to use for president account
  candidateId           String             // President ID/candidate ID
  clubOrFacultyType     String             // "CLUB" or "FACULTY"
  clubOrFacultyName     String             // Name of club or faculty
  currentQualification  String             // Current qualification/position
  email                 String             // email for president account
  status                ApplicationStatus  @default(PENDING)
  rejectionReason       String?            // Reason for rejection if rejected
  appliedAt             DateTime           @default(now())
  approvedRejectAt      DateTime?          // When it was approved/rejected
  approvedById          Int?
  approvedBy            User?              @relation(fields: [approvedById], references: [id], onDelete: SetNull)
}

// Student notifications/alerts
model StudentNotification {
  id        Int       @id @default(autoincrement())
  studentId Int
  student   Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  type      String    // "PRESIDENT_APPROVED", "PRESIDENT_REJECTED", "PASSWORD_ALERT", etc.
  title     String
  message   String
  data      String?   // JSON string for additional data (e.g., password)
  isRead    Boolean   @default(false)
  createdAt DateTime  @default(now())

  @@index([studentId])
  @@index([createdAt])
}

// User notifications (for admin/president accounts)
model UserNotification {
  id        Int       @id @default(autoincrement())
  userId    Int
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String    // "APPLICATION_CREATED", "NEW_REQUEST", etc.
  title     String
  message   String
  data      String?   // JSON string for additional data
  isRead    Boolean   @default(false)
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([createdAt])
}

// Reaction Enum for Events
enum ReactionType {
  LIKE
  LOVE
  WOW
  FUNNY
  SAD
}

// Event Reviews with Reactions
model EventReview {
  id        Int           @id @default(autoincrement())
  eventId   Int
  studentId Int
  reaction  ReactionType?  // 👍 Like, ❤️ Love, 😮 Wow, 😂 Funny, 😢 Sad
  comment   String?        // User comment
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  
  event     Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  student   Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, eventId])
  @@index([eventId])
  @@map("EventReview")
}
