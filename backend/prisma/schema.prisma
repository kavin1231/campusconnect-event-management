// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Student {
  id            Int                   @id @default(autoincrement())
  name          String
  email         String                @unique
  password      String
  studentId     String                @unique
  department    String
  year          Int
  profileImage  String?
  createdAt     DateTime              @default(now())
  registrations StudentEventRegistration[]
  presidentApplications PresidentApplication[]
}

model StudentEventRegistration {
  id         Int      @id @default(autoincrement())
  studentId  Int
  eventId    Int
  registeredAt DateTime @default(now())
  student    Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  event      Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([studentId, eventId])
}

enum Role {
  STUDENT
  EVENT_ORGANIZER
  SYSTEM_ADMIN
  CLUB_PRESIDENT
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      Role
  profileImage String?
  createdAt DateTime @default(now())

  // relations for logistics module
  assets             Asset[]          @relation("AssetOwner")
  approvedBookings   AssetBooking[]   @relation("AssetBookingApprovedBy")
  requestedBookings  AssetBooking[]   @relation("AssetBookingRequester")
  approvedApplications PresidentApplication[]

  // relations for event permission module
  submittedPermissions  EventPermissionRequest[] @relation("EventPermissionRequester")
  reviewedPermissions   EventPermissionRequest[] @relation("EventPermissionReviewer")
}

model Event {
  id              Int                   @id @default(autoincrement())
  title           String
  description     String
  date            DateTime
  category        String
  location        String
  image           String
  registeredCount Int                   @default(0)
  createdAt       DateTime              @default(now())
  registrations   StudentEventRegistration[]
}

// Logistics module models
model Asset {
  id          Int          @id @default(autoincrement())
  name        String
  description String?
  ownerId     Int
  owner       User         @relation(name: "AssetOwner", fields: [ownerId], references: [id])
  status      AssetStatus  @default(AVAILABLE)
  bookings    AssetBooking[]
  createdAt   DateTime     @default(now())
}

model AssetBooking {
  id           Int           @id @default(autoincrement())
  assetId      Int
  requesterId  Int
  startDate    DateTime
  endDate      DateTime
  status       BookingStatus @default(PENDING)
  damageReport String?
  penalty      Float?
  approvedById Int?
  approvedBy   User?         @relation(name: "AssetBookingApprovedBy", fields: [approvedById], references: [id])

  asset        Asset         @relation(fields: [assetId], references: [id], onDelete: Cascade)
  requester    User          @relation(name: "AssetBookingRequester", fields: [requesterId], references: [id])

  @@index([assetId])
  @@index([requesterId])
}

// president applications
model PresidentApplication {
  id           Int                @id @default(autoincrement())
  studentId    Int
  student      Student            @relation(fields: [studentId], references: [id])
  clubName     String
  email        String             // email for president account
  status       ApplicationStatus  @default(PENDING)
  appliedAt    DateTime           @default(now())
  approvedById Int?
  approvedBy   User?              @relation(fields: [approvedById], references: [id])
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AssetStatus {
  AVAILABLE
  UNAVAILABLE
}

enum BookingStatus {
  PENDING
  APPROVED
  REJECTED
  CHECKED_OUT
  RETURNED
  DAMAGED
}

// Event permission request model
model EventPermissionRequest {
  id                Int                    @id @default(autoincrement())
  title             String
  description       String
  eventDate         DateTime
  venue             String
  expectedAttendees Int
  budget            Float
  category          String
  organizingClub    String
  contactEmail      String
  requesterId       Int
  requester         User                   @relation(name: "EventPermissionRequester", fields: [requesterId], references: [id])
  status            EventPermissionStatus  @default(PENDING)
  rejectionReason   String?
  submittedAt       DateTime               @default(now())
  reviewedById      Int?
  reviewedBy        User?                  @relation(name: "EventPermissionReviewer", fields: [reviewedById], references: [id])

  @@index([requesterId])
  @@index([status])
}

enum EventPermissionStatus {
  PENDING
  APPROVED
  REJECTED
}
