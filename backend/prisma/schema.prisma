// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Student {
  id            Int                   @id @default(autoincrement())
  name          String
  email         String                @unique
  password      String
  studentId     String                @unique
  department    String
  year          Int
  profileImage  String?
  createdAt     DateTime              @default(now())
  registrations StudentEventRegistration[]
  presidentApplications PresidentApplication[]
  eventReviews  EventReview[]

  @@map("Student")
}

model StudentEventRegistration {
  id         Int      @id @default(autoincrement())
  studentId  Int
  eventId    Int
  registeredAt DateTime @default(now())
  student    Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  event      Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([studentId, eventId])
  @@map("StudentRegistration")
}

enum Role {
  STUDENT
  SYSTEM_ADMIN
  CLUB_PRESIDENT
  OPERATIONS_MANAGER
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      Role
  clubName  String?
  profileImage String?
  createdAt DateTime @default(now())

  // relations for logistics module
  assets             Asset[]          @relation("AssetOwner")
  approvedBookings   AssetBooking[]   @relation("AssetBookingApprovedBy")
  requestedBookings  AssetBooking[]   @relation("AssetBookingRequester")
  approvedApplications PresidentApplication[]

  // relations for study support
  studyMaterials     StudyMaterial[]  @relation("StudyMaterialCreator")
  studySessions      StudySession[]   @relation("StudySessionCreator")

  // relations for operations module
  managedOrganizations Organization[] @relation("OrganizationManager")
  sponsorshipLeads     SponsorshipLead[] @relation("SponsorshipManagedBy")
  approvedVendors      VendorPartner[] @relation("VendorApprovedBy")
  allocatedStalls      StallSlot[] @relation("StallAllocatedBy")
  createdBudgetEntries OrganizationBudget[] @relation("BudgetCreatedBy")

  @@map("User")
}

model Event {
  id              Int                   @id @default(autoincrement())
  title           String
  description     String
  date            DateTime
  category        String
  location        String
  image           String
  registeredCount Int                   @default(0)
  createdAt       DateTime              @default(now())
  registrations   StudentEventRegistration[]
  reviews         EventReview[]

  @@map("Event")
}

// Logistics module models
model Asset {
  id          Int          @id @default(autoincrement())
  name        String
  description String?
  ownerId     Int
  owner       User         @relation(name: "AssetOwner", fields: [ownerId], references: [id])
  status      AssetStatus  @default(AVAILABLE)
  bookings    AssetBooking[]
  createdAt   DateTime     @default(now())
}

model AssetBooking {
  id           Int           @id @default(autoincrement())
  assetId      Int
  requesterId  Int
  startDate    DateTime
  endDate      DateTime
  status       BookingStatus @default(PENDING)
  damageReport String?
  penalty      Float?
  approvedById Int?
  approvedBy   User?         @relation(name: "AssetBookingApprovedBy", fields: [approvedById], references: [id])

  asset        Asset         @relation(fields: [assetId], references: [id], onDelete: Cascade)
  requester    User          @relation(name: "AssetBookingRequester", fields: [requesterId], references: [id])

  @@index([assetId])
  @@index([requesterId])
}

// president applications
model PresidentApplication {
  id           Int                @id @default(autoincrement())
  studentId    Int
  student      Student            @relation(fields: [studentId], references: [id])
  clubName     String
  email        String             // email for president account
  status       ApplicationStatus  @default(PENDING)
  appliedAt    DateTime           @default(now())
  approvedById Int?
  approvedBy   User?              @relation(fields: [approvedById], references: [id])
}

// Study Support and Materials
model StudyMaterial {
  id            Int       @id @default(autoincrement())
  semester      String    // Y1S1, Y1S2, Y2S1, Y2S2, Y3S1, Y3S2, Y4S1, Y4S2
  title         String
  description   String?
  materialType  String    // pdf, link, video, other
  contentUrl    String    // URL for links or PDF download
  uploadedAt    DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  createdBy     Int       // Admin ID
  creator       User      @relation(name: "StudyMaterialCreator", fields: [createdBy], references: [id])
}

model StudySession {
  id            Int       @id @default(autoincrement())
  semester      String    // Y1S1, Y1S2, Y2S1, Y2S2, Y3S1, Y3S2, Y4S1, Y4S2
  title         String
  description   String
  sessionDate   DateTime
  sessionLink   String?   // Zoom/Meet link
  sessionNotes  String?   // Additional notes
  uploadedAt    DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  createdBy     Int       // Admin ID
  creator       User      @relation(name: "StudySessionCreator", fields: [createdBy], references: [id])
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AssetStatus {
  AVAILABLE
  UNAVAILABLE
}

enum BookingStatus {
  PENDING
  APPROVED
  REJECTED
  CHECKED_OUT
  RETURNED
  DAMAGED
}

// Reaction Enum for Events
enum ReactionType {
  LIKE
  LOVE
  WOW
  FUNNY
  SAD
}

// Event Reviews with Reactions
model EventReview {
  id        Int           @id @default(autoincrement())
  eventId   Int
  studentId Int
  reaction  ReactionType?  // 👍 Like, ❤️ Love, 😮 Wow, 😂 Funny, 😢 Sad
  comment   String?        // User comment
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  
  event     Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  student   Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, eventId])
  @@index([eventId])
  @@map("EventReview")
}
// Operations and sponsorship models
model Organization {
  id            Int      @id @default(autoincrement())
  name          String
  faculty       String
  description   String?
  contactEmail  String   @unique
  contactPhone  String?
  logoUrl       String?
  themePrimary  String?  @default("#FF6B35")
  themeAccent   String?  @default("#1E293B")
  managerId     Int
  manager       User     @relation("OrganizationManager", fields: [managerId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  sponsorshipLeads SponsorshipLead[]
  budgetEntries    OrganizationBudget[]
  vendors          VendorPartner[]
  stallSlots       StallSlot[]

  @@index([managerId])
}

model SponsorshipLead {
  id                Int                    @id @default(autoincrement())
  organizationId    Int
  sponsorName       String
  sponsorEmail      String?
  contactPerson     String?
  packageTier       SponsorPackageTier?
  stage             SponsorshipStage       @default(LEAD)
  expectedValue     Float?
  confirmedValue    Float?
  inKindDescription String?
  benefitsChecklist Json?
  notes             String?
  lastMovedAt       DateTime               @default(now())
  managedById       Int
  managedBy         User                   @relation("SponsorshipManagedBy", fields: [managedById], references: [id])
  organization      Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contributions     SponsorContribution[]
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  @@index([organizationId])
  @@index([stage])
  @@unique([organizationId, sponsorName])
}

model SponsorContribution {
  id              Int                 @id @default(autoincrement())
  sponsorshipId   Int
  type            ContributionType
  amount          Float?
  inKindValue     Float?
  description     String?
  paidAt          DateTime            @default(now())
  sponsorshipLead SponsorshipLead     @relation(fields: [sponsorshipId], references: [id], onDelete: Cascade)

  @@index([sponsorshipId])
}

model OrganizationBudget {
  id             Int      @id @default(autoincrement())
  organizationId Int
  eventId        Int?
  category       String
  plannedAmount  Float
  actualAmount   Float    @default(0)
  notes          String?
  createdById    Int
  createdBy      User         @relation("BudgetCreatedBy", fields: [createdById], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId])
  @@index([eventId])
  @@unique([organizationId, category])
}

model VendorPartner {
  id                Int                   @id @default(autoincrement())
  organizationId    Int
  name              String
  contactName       String
  contactPhone      String
  contactEmail      String?
  requirements      Json?
  agreementStatus   VendorAgreementStatus @default(DRAFT)
  approvedById      Int?
  approvedBy        User?                 @relation("VendorApprovedBy", fields: [approvedById], references: [id])
  organization      Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  stallSlots        StallSlot[]

  @@index([organizationId])
  @@index([agreementStatus])
  @@unique([organizationId, name])
}

model StallSlot {
  id             Int      @id @default(autoincrement())
  organizationId Int
  vendorId       Int?
  slotCode       String
  location       String
  eventDate      DateTime
  startTime      DateTime
  endTime        DateTime
  allocatedById  Int?
  allocatedBy    User?        @relation("StallAllocatedBy", fields: [allocatedById], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  vendor         VendorPartner? @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId])
  @@index([vendorId])
  @@unique([organizationId, slotCode, eventDate, startTime])
}

enum SponsorshipStage {
  LEAD
  CONTACTED
  PROPOSAL
  NEGOTIATION
  CONFIRMED
}

enum SponsorPackageTier {
  GOLD
  SILVER
  BRONZE
}

enum ContributionType {
  PAYMENT
  IN_KIND
}

enum VendorAgreementStatus {
  DRAFT
  UNDER_REVIEW
  SIGNED
  EXPIRED
}

// Sports Management
model Sport {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  coachName   String?
  whatsappLink String?
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("Sport")
}
