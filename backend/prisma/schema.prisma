// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  output          = "../generated/prisma"
  engineType      = "library"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model Student {
  id            Int                   @id @default(autoincrement())
  name          String
  email         String                @unique
  password      String
  studentId     String                @unique
  department    String
  year          Int
  profileImage  String?
  createdAt     DateTime              @default(now())
  registrations StudentEventRegistration[]
  presidentApplications PresidentApplication[]
  notifications StudentNotification[]
  eventReviews  EventReview[]

  @@map("Student")
}

model StudentEventRegistration {
  id         Int      @id @default(autoincrement())
  studentId  Int
  eventId    Int
  registeredAt DateTime @default(now())
  student    Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  event      Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([studentId, eventId])
  @@map("StudentRegistration")
}

enum Role {
  STUDENT
  SYSTEM_ADMIN
  CLUB_PRESIDENT
  OPERATIONS_MANAGER
}

enum ClubStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  ARCHIVED
}

enum ClubRole {
  PRESIDENT
  VICE_PRESIDENT
  TREASURER
  MEMBER
}

enum AssetStatus {
  AVAILABLE
  UNAVAILABLE
  MAINTENANCE
  DAMAGED
  ARCHIVED
}

enum AssetCondition {
  EXCELLENT
  GOOD
  FAIR
  POOR
  DAMAGED
}

enum AssetCategory {
  EQUIPMENT
  FURNITURE
  TECHNOLOGY
  SPORTS
  SOUND_SYSTEM
  DECORATION
  VEHICLES
  OTHER
}

enum BookingStatus {
  PENDING
  APPROVED
  REJECTED
  CHECKED_OUT
  RETURNED
  CANCELLED
  DAMAGED
}

enum DamageType {
  PHYSICAL
  MECHANICAL
  ELECTRONIC
  STRUCTURAL
  OTHER
}

enum DamageSeverity {
  MINOR
  MODERATE
  MAJOR
  CRITICAL
}

enum DamageStatus {
  PENDING
  APPROVED
  REJECTED
  RESOLVED
  IN_PROGRESS
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id               Int      @id @default(autoincrement())
  name             String
  email            String   @unique
  password         String
  role             Role
  profileImage     String?
  
  // Club relations  
  clubId           Int?
  club             Club?    @relation("ClubMembers", fields: [clubId], references: [id], onDelete: SetNull)
  clubRole         ClubRole?
  presidingClub    Club?    @relation("ClubPresident")
  
  // relationships for logistics module
  approvedBookings AssetBooking[]   @relation("AssetBookingApprovedBy")
  requestedBookings AssetBooking[]  @relation("AssetBookingRequester")
  approvedReturns  AssetBooking[]   @relation("ReturnApprovedBy")
  damageReports    DamageReport[]
  damageApprovals  DamageReport[]   @relation("DamageApprovedBy")
  
  approvedApplications PresidentApplication[]
  notifications    UserNotification[]

  // relations for study support
  studyMaterials   StudyMaterial[]  @relation("StudyMaterialCreator")
  studySessions    StudySession[]   @relation("StudySessionCreator")
  
  createdAt        DateTime @default(now())

  // relations for operations module
  managedOrganizations Organization[] @relation("OrganizationManager")
  sponsorshipLeads     SponsorshipLead[] @relation("SponsorshipManagedBy")
  approvedVendors      VendorPartner[] @relation("VendorApprovedBy")
  allocatedStalls      StallSlot[] @relation("StallAllocatedBy")
  createdBudgetEntries OrganizationBudget[] @relation("BudgetCreatedBy")

  @@map("User")
}

model Event {
  id              Int                   @id @default(autoincrement())
  title           String
  description     String
  date            DateTime
  category        String
  location        String
  image           String
  registeredCount Int                   @default(0)
  createdAt       DateTime              @default(now())
  registrations   StudentEventRegistration[]
  reviews         EventReview[]

  @@map("Event")
}

// ========== CLUB MANAGEMENT ==========
model Club {
  id                Int                @id @default(autoincrement())
  name              String             @unique
  description       String?
  clubType          String             // "ACADEMIC", "SOCIAL", "SPORTS", "CULTURAL"
  logo              String?            // Image URL
  members           User[]             @relation("ClubMembers")
  president         User?              @relation("ClubPresident", fields: [presidentId], references: [id])
  presidentId       Int?               @unique
  status            ClubStatus         @default(ACTIVE)
  
  // Assets and logistics
  assets            Asset[]            @relation("ClubAssets")
  requestsSent      AssetBooking[]     @relation("RequestingClub")
  requestsReceived  AssetBooking[]     @relation("OwningClub")
  damageReports     DamageReport[]
  
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@index([status])
  @@map("Club")
}

// ========== ENHANCED LOGISTICS MODELS ==========
model Asset {
  id               Int                 @id @default(autoincrement())
  name             String
  description      String?
  category         AssetCategory
  quantity         Int                 @default(1)
  availableQty     Int                 @default(1)
  condition        AssetCondition      @default(GOOD)
  
  // Owner club
  clubId           Int
  club             Club                @relation(name: "ClubAssets", fields: [clubId], references: [id], onDelete: Cascade)
  
  // Images
  images           String[]            // Array of image URLs
  thumbnail        String?
  
  // Metadata
  value            Float?              // Asset value for insurance
  status           AssetStatus         @default(AVAILABLE)
  
  // Relationships
  bookings         AssetBooking[]
  damageReports    DamageReport[]
  
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  @@index([clubId])
  @@index([status])
  @@index([category])
  @@map("Asset")
}

model AssetBooking {
  id                  Int                @id @default(autoincrement())
  assetId             Int
  asset               Asset              @relation(fields: [assetId], references: [id], onDelete: Cascade)
  
  // Requesting club details
  requestingClubId    Int
  requestingClub      Club               @relation(name: "RequestingClub", fields: [requestingClubId], references: [id], onDelete: Cascade)
  
  // Asset owner club
  owningClubId        Int
  owningClub          Club               @relation(name: "OwningClub", fields: [owningClubId], references: [id], onDelete: Cascade)
  
  // User who requested
  requesterId         Int
  requester           User               @relation(name: "AssetBookingRequester", fields: [requesterId], references: [id])
  
  // Booking details
  quantityRequested   Int                @default(1)
  startDate           DateTime
  endDate             DateTime
  purpose             String?
  
  // Approval
  status              BookingStatus      @default(PENDING)
  approvedById        Int?
  approvedBy          User?              @relation(name: "AssetBookingApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)
  approvedAt          DateTime?
  rejectionReason     String?
  
  // Return tracking
  checkedOutAt        DateTime?
  returnedAt          DateTime?
  approvedReturnBy    Int?
  approvedReturnUser  User?              @relation(name: "ReturnApprovedBy", fields: [approvedReturnBy], references: [id], onDelete: SetNull)
  
  // Damage & penalties
  damageReport        DamageReport?
  penalty             Float?             @default(0)
  
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  @@unique([assetId, requestingClubId, startDate, endDate])
  @@index([assetId])
  @@index([requestingClubId])
  @@index([owningClubId])
  @@index([requesterId])
  @@index([status])
  @@map("AssetBooking")
}

model DamageReport {
  id              Int                @id @default(autoincrement())
  bookingId       Int?               @unique
  booking         AssetBooking?      @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  
  assetId         Int
  asset           Asset              @relation(fields: [assetId], references: [id], onDelete: Cascade)
  
  clubId          Int
  club            Club               @relation(fields: [clubId], references: [id], onDelete: Cascade)
  
  reportedBy      Int
  reporter        User               @relation(fields: [reportedBy], references: [id])
  
  title           String
  description     String
  damageType      DamageType
  severity        DamageSeverity
  
  images          String[]           // Damage photos
  estimatedCost   Float?
  actualCost      Float?
  
  status          DamageStatus       @default(PENDING)
  approvedById    Int?
  approvedBy      User?              @relation(name: "DamageApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)
  
  penalty         Float?
  resolutionNotes String?
  
  createdAt       DateTime           @default(now())
  resolvedAt      DateTime?

  @@index([assetId])
  @@index([clubId])
  @@index([status])
  @@map("DamageReport")
}

// president applications
model PresidentApplication {
  id                    Int                @id @default(autoincrement())
  studentId             Int
  student               Student            @relation(fields: [studentId], references: [id], onDelete: Cascade)
  presidentName         String             // The name to use for president account
  candidateId           String             // President ID/candidate ID
  clubOrFacultyType     String             // "CLUB" or "FACULTY"
  clubOrFacultyName     String             // Name of club or faculty
  currentQualification  String             // Current qualification/position
  email                 String             // email for president account
  status                ApplicationStatus  @default(PENDING)
  rejectionReason       String?            // Reason for rejection if rejected
  appliedAt             DateTime           @default(now())
  approvedRejectAt      DateTime?          // When it was approved/rejected
  approvedById          Int?
  approvedBy            User?              @relation(fields: [approvedById], references: [id], onDelete: SetNull)
}

// Student notifications/alerts
model StudentNotification {
  id        Int       @id @default(autoincrement())
  studentId Int
  student   Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  type      String    // "PRESIDENT_APPROVED", "PRESIDENT_REJECTED", "PASSWORD_ALERT", etc.
  title     String
  message   String
  data      String?   // JSON string for additional data (e.g., password)
  isRead    Boolean   @default(false)
  createdAt DateTime  @default(now())

  @@index([studentId])
  @@index([createdAt])
}

// User notifications (for admin/president accounts)
model UserNotification {
  id        Int       @id @default(autoincrement())
  userId    Int
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String    // "APPLICATION_CREATED", "NEW_REQUEST", etc.
  title     String
  message   String
  data      String?   // JSON string for additional data
  isRead    Boolean   @default(false)
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([createdAt])
}

// Study Support and Materials
model StudyMaterial {
  id            Int       @id @default(autoincrement())
  semester      String    // Y1S1, Y1S2, Y2S1, Y2S2, Y3S1, Y3S2, Y4S1, Y4S2
  title         String
  description   String?
  materialType  String    // pdf, link, video, other
  contentUrl    String    // URL for links or PDF download
  uploadedAt    DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  createdBy     Int       // Admin ID
  creator       User      @relation(name: "StudyMaterialCreator", fields: [createdBy], references: [id])
}

model StudySession {
  id            Int       @id @default(autoincrement())
  semester      String    // Y1S1, Y1S2, Y2S1, Y2S2, Y3S1, Y3S2, Y4S1, Y4S2
  title         String
  description   String
  sessionDate   DateTime
  sessionLink   String?   // Zoom/Meet link
  sessionNotes  String?   // Additional notes
  uploadedAt    DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  createdBy     Int       // Admin ID
  creator       User      @relation(name: "StudySessionCreator", fields: [createdBy], references: [id])
}

// Reaction Enum for Events
enum ReactionType {
  LIKE
  LOVE
  WOW
  FUNNY
  SAD
}

// Event Reviews with Reactions
model EventReview {
  id        Int           @id @default(autoincrement())
  eventId   Int
  studentId Int
  reaction  ReactionType?  // 👍 Like, ❤️ Love, 😮 Wow, 😂 Funny, 😢 Sad
  comment   String?        // User comment
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  
  event     Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  student   Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, eventId])
  @@index([eventId])
  @@map("EventReview")
}
// Operations and sponsorship models
model Organization {
  id            Int      @id @default(autoincrement())
  name          String
  faculty       String
  description   String?
  contactEmail  String   @unique
  contactPhone  String?
  logoUrl       String?
  themePrimary  String?  @default("#FF6B35")
  themeAccent   String?  @default("#1E293B")
  managerId     Int
  manager       User     @relation("OrganizationManager", fields: [managerId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  sponsorshipLeads SponsorshipLead[]
  budgetEntries    OrganizationBudget[]
  vendors          VendorPartner[]
  stallSlots       StallSlot[]

  @@index([managerId])
}

model SponsorshipLead {
  id                Int                    @id @default(autoincrement())
  organizationId    Int
  sponsorName       String
  sponsorEmail      String?
  contactPerson     String?
  packageTier       SponsorPackageTier?
  stage             SponsorshipStage       @default(LEAD)
  expectedValue     Float?
  confirmedValue    Float?
  inKindDescription String?
  benefitsChecklist Json?
  notes             String?
  lastMovedAt       DateTime               @default(now())
  managedById       Int
  managedBy         User                   @relation("SponsorshipManagedBy", fields: [managedById], references: [id])
  organization      Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contributions     SponsorContribution[]
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  @@index([organizationId])
  @@index([stage])
  @@unique([organizationId, sponsorName])
}

model SponsorContribution {
  id              Int                 @id @default(autoincrement())
  sponsorshipId   Int
  type            ContributionType
  amount          Float?
  inKindValue     Float?
  description     String?
  paidAt          DateTime            @default(now())
  sponsorshipLead SponsorshipLead     @relation(fields: [sponsorshipId], references: [id], onDelete: Cascade)

  @@index([sponsorshipId])
}

model OrganizationBudget {
  id             Int      @id @default(autoincrement())
  organizationId Int
  eventId        Int?
  category       String
  plannedAmount  Float
  actualAmount   Float    @default(0)
  notes          String?
  createdById    Int
  createdBy      User         @relation("BudgetCreatedBy", fields: [createdById], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId])
  @@index([eventId])
  @@unique([organizationId, category])
}

model VendorPartner {
  id                Int                   @id @default(autoincrement())
  organizationId    Int
  name              String
  contactName       String
  contactPhone      String
  contactEmail      String?
  requirements      Json?
  agreementStatus   VendorAgreementStatus @default(DRAFT)
  approvedById      Int?
  approvedBy        User?                 @relation("VendorApprovedBy", fields: [approvedById], references: [id])
  organization      Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  stallSlots        StallSlot[]

  @@index([organizationId])
  @@index([agreementStatus])
  @@unique([organizationId, name])
}

model StallSlot {
  id             Int      @id @default(autoincrement())
  organizationId Int
  vendorId       Int?
  slotCode       String
  location       String
  eventDate      DateTime
  startTime      DateTime
  endTime        DateTime
  allocatedById  Int?
  allocatedBy    User?        @relation("StallAllocatedBy", fields: [allocatedById], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  vendor         VendorPartner? @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId])
  @@index([vendorId])
  @@unique([organizationId, slotCode, eventDate, startTime])
}

enum SponsorshipStage {
  LEAD
  CONTACTED
  PROPOSAL
  NEGOTIATION
  CONFIRMED
}

enum SponsorPackageTier {
  GOLD
  SILVER
  BRONZE
}

enum ContributionType {
  PAYMENT
  IN_KIND
}

enum VendorAgreementStatus {
  DRAFT
  UNDER_REVIEW
  SIGNED
  EXPIRED
}

// Sports Management
model Sport {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  coachName   String?
  whatsappLink String?
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("Sport")
}
