generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Student {
  id                    Int                        @id @default(autoincrement())
  name                  String
  email                 String                     @unique
  password              String
  studentId             String                     @unique
  department            String
  year                  Int
  profileImage          String?
  createdAt             DateTime                   @default(now())
  eventReviews          EventReview[]
  presidentApplications PresidentApplication[]
  notifications         StudentNotification[]
  registrations         StudentEventRegistration[]

  @@map("Student")
}

model StudentEventRegistration {
  id           Int      @id @default(autoincrement())
  studentId    Int
  eventId      Int
  registeredAt DateTime @default(now())
  event        Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  student      Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, eventId])
  @@map("StudentRegistration")
}

model User {
  id                     Int                    @id @default(autoincrement())
  name                   String
  email                  String                 @unique
  password               String
  role                   Role
  profileImage           String?
  createdAt              DateTime               @default(now())
  clubOrFacultyName      String?
  clubOrFacultyType      String?
  approvedBookings       AssetBooking[]         @relation("AssetBookingApprovedBy")
  approvedReturns        AssetBooking[]         @relation("ReturnApprovedBy")
  requestedBookings      AssetBooking[]         @relation("AssetBookingRequester")
  presidingClub          Club[]                 @relation("ClubPresident")
  ClubMember             ClubMember[]
  damageReports          DamageReport[]
  eventRequestsReviewed  EventRequest[]         @relation("EventRequestReviewer")
  eventRequestsSubmitted EventRequest[]         @relation("EventRequestSubmitter")
  FinanceRecord          FinanceRecord[]
  managedOrganizations   Organization[]
  createdBudgets         OrganizationBudget[]
  managedSponsorshipLeads SponsorshipLead[]
  approvedVendors        VendorPartner[]
  approvedApplications   PresidentApplication[]
  allocatedStallSlots    StallSlot[]
  studyMaterials         StudyMaterial[]        @relation("StudyMaterialCreator")
  studySessions          StudySession[]         @relation("StudySessionCreator")
  notifications          UserNotification[]
  delegates              EventDelegate[]        @relation("EventDelegates")
  delegateActions        EventDelegateHistory[] @relation("DelegateActionPerformedBy")

  @@map("User")
}

model Event {
  id                 Int                        @id @default(autoincrement())
  title              String
  description        String
  date               DateTime
  category           String
  location           String
  image              String
  startTime          String?
  endTime            String?
  registeredCount    Int                        @default(0)
  status             String                     @default("PENDING")
  budget             Int?
  expectedAttendees  Int?
  venue              String?
  submittedBy        Int?
  submittedDate      DateTime?                  @default(now())
  approvedBy         Int?
  approvedAt         DateTime?
  rejectionReason    String?
  createdAt          DateTime                   @default(now())
  organizer          String?
  organizerId        String?
  organizerType      String?
  updatedAt          DateTime?                  @default(now()) @updatedAt @db.Timestamptz(6)
  reviews            EventReview[]
  EventStall         EventStall[]
  OrganizationBudget OrganizationBudget[]
  SponsorshipLead    SponsorshipLead[]
  eventRequestId     Int?                       @unique
  eventRequest       EventRequest?              @relation("EventRequestToEvent", fields: [eventRequestId], references: [id])
  registrations      StudentEventRegistration[]

  @@map("Event")
}

model EventRequest {
  id                   Int                @id @default(autoincrement())
  title                String
  eventType            String
  eventTypeOther       String?
  purposeTag           String
  purposeDescription   String
  bannerUrl            String?
  eventDate            DateTime
  startTime            String
  endTime              String
  setupTime            String
  teardownTime         String
  audience             String
  organizingBody       String?
  contactName          String?
  contactId            String?
  contactPhone         String?
  contactEmail         String?
  supervisorName       String?
  supervisorDepartment String?
  supervisorPhone      String?
  venue                String?
  expectedAttendance   Int?
  seatingArrangement   String?
  parkingRequired      Boolean            @default(false)
  estimatedBudget      Float?
  budgetBreakdown      String?
  sponsorshipDetails   String?
  fundSource           String?
  riskAssessment       String?
  safetyMeasures       String?
  emergencyPlan        String?
  contingency          String?
  tickets              Json               @default("[]")
  merchandise          Json               @default("[]")
  status               EventRequestStatus @default(PENDING)
  submittedBy          Int
  submittedAt          DateTime           @default(now())
  reviewedBy           Int?
  reviewedAt           DateTime?
  reviewNotes          String?
  updatedAt            DateTime           @updatedAt
  reviewer             User?              @relation("EventRequestReviewer", fields: [reviewedBy], references: [id])
  submitter            User               @relation("EventRequestSubmitter", fields: [submittedBy], references: [id])
  delegates            EventDelegate[]
  delegateHistory      EventDelegateHistory[]
  event                Event?             @relation("EventRequestToEvent")
  merchandiseProducts  MerchandiseProduct[]
  merchandiseOrders    MerchandiseOrder[]

  @@index([status])
  @@index([submittedAt])
  @@map("EventRequest")
}

model Club {
  id               Int            @id @default(autoincrement())
  name             String         @unique
  description      String?
  clubType         String?
  logo             String?
  status           String         @default("ACTIVE")
  createdAt        DateTime       @default(now())
  presidentId      Int?
  assets           Asset[]        @relation("ClubAssets")
  requestsReceived AssetBooking[] @relation("OwningClub")
  requestsSent     AssetBooking[] @relation("RequestingClub")
  president        User?          @relation("ClubPresident", fields: [presidentId], references: [id])
  ClubMember       ClubMember[]
  damageReports    DamageReport[]

  @@map("Club")
}

model Asset {
  id                Int                 @id @default(autoincrement())
  name              String
  description       String?
  imageUrl          String?             @default("https://images.unsplash.com/photo-1505228395891-9a51e7e86e81?auto=format&fit=crop&q=80&w=400")
  ownerId           Int
  clubId            Int?
  status            AssetStatus         @default(AVAILABLE)
  quantity          Int                 @default(1)
  createdAt         DateTime            @default(now())
  club              Club?               @relation("ClubAssets", fields: [clubId], references: [id])
  bookings          AssetBooking[]
  damageReports     DamageReport[]
  MaintenanceRecord MaintenanceRecord[]

  @@map("Asset")
}

model AssetBooking {
  id                 Int           @id @default(autoincrement())
  assetId            Int
  requesterId        Int
  requestingClubId   Int?
  owningClubId       Int?
  startDate          DateTime
  endDate            DateTime
  quantityRequested  Int           @default(1)
  purpose            String?
  status             BookingStatus @default(PENDING)
  approvedById       Int?
  approvedAt         DateTime?
  checkedOutAt       DateTime?
  returnedAt         DateTime?
  approvedReturnBy   Int?
  penalty            Float?        @default(0)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  approvedBy         User?         @relation("AssetBookingApprovedBy", fields: [approvedById], references: [id])
  approvedReturnUser User?         @relation("ReturnApprovedBy", fields: [approvedReturnBy], references: [id])
  asset              Asset         @relation(fields: [assetId], references: [id], onDelete: Cascade)
  owningClub         Club?         @relation("OwningClub", fields: [owningClubId], references: [id])
  requester          User          @relation("AssetBookingRequester", fields: [requesterId], references: [id])
  requestingClub     Club?         @relation("RequestingClub", fields: [requestingClubId], references: [id])

  @@index([assetId])
  @@index([requesterId])
  @@index([status])
  @@map("AssetBooking")
}

model DamageReport {
  id            Int      @id @default(autoincrement())
  assetId       Int
  bookingId     Int?
  clubId        Int
  reportedBy    Int
  title         String
  description   String
  damageType    String
  severity      String
  status        String   @default("PENDING")
  images        String[] @default([])
  estimatedCost Float?
  resolution    String?
  createdAt     DateTime @default(now())
  asset         Asset    @relation(fields: [assetId], references: [id])
  club          Club     @relation(fields: [clubId], references: [id])
  reporter      User     @relation(fields: [reportedBy], references: [id])

  @@map("DamageReport")
}

model PresidentApplication {
  id                   Int               @id @default(autoincrement())
  studentId            Int
  presidentName        String
  candidateId          String
  clubOrFacultyType    String
  clubOrFacultyName    String
  currentQualification String
  email                String
  status               ApplicationStatus @default(PENDING)
  rejectionReason      String?
  appliedAt            DateTime          @default(now())
  approvedRejectAt     DateTime?
  approvedById         Int?
  approvedBy           User?             @relation(fields: [approvedById], references: [id])
  student              Student           @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model StudentNotification {
  id        Int      @id @default(autoincrement())
  studentId Int
  type      String
  title     String
  message   String
  data      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([createdAt])
}

model UserNotification {
  id        Int      @id @default(autoincrement())
  userId    Int
  type      String
  title     String
  message   String
  data      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model StudyMaterial {
  id           Int      @id @default(autoincrement())
  semester     String
  title        String
  description  String?
  materialType String
  contentUrl   String
  uploadedAt   DateTime @default(now())
  createdBy    Int
  creator      User     @relation("StudyMaterialCreator", fields: [createdBy], references: [id])
}

model StudySession {
  id           Int      @id @default(autoincrement())
  semester     String
  title        String
  description  String?
  sessionDate  DateTime
  sessionLink  String?
  sessionNotes String?
  createdAt    DateTime @default(now())
  createdBy    Int
  creator      User     @relation("StudySessionCreator", fields: [createdBy], references: [id])
}

model EventReview {
  id        Int           @id @default(autoincrement())
  eventId   Int
  studentId Int
  reaction  ReactionType?
  comment   String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  event     Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  student   Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, eventId])
  @@index([eventId])
  @@map("EventReview")
}

model MerchandiseProduct {
  id          Int                      @id @default(autoincrement())
  name        String
  description String?
  price       Float                    @default(0)
  imageUrl    String?
  status      MerchandiseProductStatus @default(IN_STOCK)
  inventory   Int                      @default(0)
  isActive    Boolean                  @default(true)
  
  eventRequestId Int?
  eventRequest   EventRequest?         @relation(fields: [eventRequestId], references: [id], onDelete: SetNull)
  
  orderItems  MerchandiseOrderItem[]
  
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt

  @@index([status])
  @@map("MerchandiseProduct")
}

model MerchandiseOrder {
  id              Int                    @id @default(autoincrement())
  buyerId         Int?
  buyerName       String
  buyerEmail      String?
  buyerPhone      String?
  studentNumber   String?
  totalAmount     Float                  @default(0)
  status          MerchandiseOrderStatus @default(PENDING)
  notes           String?
  paymentSlipUrl  String?
  
  eventRequestId  Int?
  eventRequest    EventRequest?          @relation(fields: [eventRequestId], references: [id], onDelete: SetNull)
  
  items           MerchandiseOrderItem[]
  
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  @@index([status])
  @@index([buyerId])
  @@map("MerchandiseOrder")
}

model MerchandiseOrderItem {
  id        Int                @id @default(autoincrement())
  orderId   Int
  order     MerchandiseOrder   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  productId Int
  product   MerchandiseProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  quantity  Int                @default(1)
  unitPrice Float              @default(0)
  size      String?
  
  createdAt DateTime           @default(now())

  @@index([orderId])
  @@index([productId])
  @@map("MerchandiseOrderItem")
}

model ClubMember {
  id       Int      @id @default(autoincrement())
  clubId   Int
  userId   Int
  clubRole String   @default("MEMBER")
  joinedAt DateTime @default(now())
  Club     Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  User     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([clubId, userId])
}

model EventStall {
  id              Int            @id @default(autoincrement())
  eventId         Int
  stallNumber     Int
  status          String         @default("AVAILABLE")
  vendorId        Int?
  serviceCategory String?
  mapX            Float
  mapY            Float
  createdAt       DateTime       @default(now())
  updatedAt       DateTime
  event           Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  vendor          VendorPartner? @relation(fields: [vendorId], references: [id])

  @@unique([eventId, stallNumber])
  @@unique([eventId, vendorId])
  @@index([eventId, status])
}

model FinanceRecord {
  id              Int      @id @default(autoincrement())
  type            String
  title           String
  category        String
  amount          Float
  transactionDate DateTime
  notes           String?
  createdById     Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime
  User            User     @relation(fields: [createdById], references: [id], onDelete: Cascade)

  @@index([category])
  @@index([transactionDate])
  @@index([type])
}

model GroupLink {
  id        Int      @id @default(autoincrement())
  name      String
  platform  String
  url       String
  category  String
  createdAt DateTime @default(now())
}

model MaintenanceRecord {
  id              Int       @id @default(autoincrement())
  assetId         Int
  maintenanceType String
  description     String
  cost            Float     @default(0)
  performedAt     DateTime
  nextServiceAt   DateTime?
  createdAt       DateTime  @default(now())
  Asset           Asset     @relation(fields: [assetId], references: [id], onDelete: Cascade)
}

model Organization {
  id                 Int                  @id @default(autoincrement())
  name               String
  faculty            String
  contactEmail       String
  contactPhone       String?
  description        String?
  logoUrl            String?
  themePrimary       String?
  themeAccent        String?
  createdAt          DateTime             @default(now())
  managerId          Int
  manager            User                 @relation(fields: [managerId], references: [id])
  OrganizationBudget OrganizationBudget[]
  SponsorshipLead    SponsorshipLead[]
  StallSlot          StallSlot[]
  VendorPartner      VendorPartner[]
}

model OrganizationBudget {
  id             Int          @id @default(autoincrement())
  organizationId Int
  eventId        Int?
  category       String
  plannedAmount  Float
  actualAmount   Float        @default(0)
  notes          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime
  createdById    Int
  createdBy      User         @relation(fields: [createdById], references: [id])
  event          Event?       @relation(fields: [eventId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id])
}

model SponsorContribution {
  id              Int             @id @default(autoincrement())
  sponsorshipId   Int
  type            String
  amount          Float?
  inKindValue     Float?
  description     String?
  createdAt       DateTime        @default(now())
  SponsorshipLead SponsorshipLead @relation(fields: [sponsorshipId], references: [id], onDelete: Cascade)
}

model SponsorshipLead {
  id                  Int                   @id @default(autoincrement())
  organizationId      Int?
  eventId             Int?
  sponsorName         String
  companyName         String                @default("")
  sponsorEmail        String?
  contactPerson       String?
  contactPhone        String?
  sponsorshipType     String?
  paymentStatus       String                @default("PENDING")
  sponsorshipAmount   Float                 @default(0)
  sponsorTier         String                @default("BRONZE")
  status              String                @default("ACTIVE")
  packageTier         String?
  expectedValue       Float?
  confirmedValue      Float?
  stage               String                @default("LEAD")
  benefitsChecklist   Json?
  notes               String?
  lastMovedAt         DateTime              @default(now())
  createdAt           DateTime              @default(now())
  updatedAt           DateTime
  managedById         Int
  SponsorContribution SponsorContribution[]
  event               Event?                @relation(fields: [eventId], references: [id])
  managedBy           User                  @relation(fields: [managedById], references: [id])
  organization        Organization?         @relation(fields: [organizationId], references: [id])
}

model Sport {
  id           Int      @id @default(autoincrement())
  name         String   @unique
  description  String?
  coachName    String?
  whatsappLink String?
  imageUrl     String?
  createdAt    DateTime @default(now())
}

model StallSlot {
  id             Int            @id @default(autoincrement())
  organizationId Int
  vendorId       Int?
  slotCode       String
  location       String
  eventDate      DateTime
  startTime      DateTime
  endTime        DateTime
  status         String         @default("AVAILABLE")
  allocatedById  Int?
  createdAt      DateTime       @default(now())
  User           User?          @relation(fields: [allocatedById], references: [id])
  Organization   Organization   @relation(fields: [organizationId], references: [id])
  VendorPartner  VendorPartner? @relation(fields: [vendorId], references: [id])
}

model VendorPartner {
  id              Int           @id @default(autoincrement())
  organizationId  Int?
  name            String
  companyName     String        @default("")
  serviceCategory String        @default("")
  contactName     String
  contactPhone    String
  contactEmail    String?
  address         String        @default("")
  requirements    String?
  status          String        @default("ACTIVE")
  agreementStatus String        @default("NOT_STARTED")
  approvedById    Int?
  createdAt       DateTime      @default(now())
  vendorFee       Float         @default(0)
  eventStallAllocations EventStall[]
  StallSlot       StallSlot[]
  approvedBy      User?         @relation(fields: [approvedById], references: [id])
  organization    Organization? @relation(fields: [organizationId], references: [id])
}

enum Role {
  STUDENT
  SYSTEM_ADMIN
  CLUB_PRESIDENT
  OPERATIONS_MANAGER
  EVENT_ORGANIZER
  TECHNICAL_STAFF
}

enum DelegateRole {
  CO_ORGANIZER
  MANAGER
  LOGISTICS
  FINANCES
}

enum AssetStatus {
  AVAILABLE
  UNAVAILABLE
  MAINTENANCE
  DAMAGED
  ARCHIVED
}

enum BookingStatus {
  PENDING
  APPROVED
  REJECTED
  CHECKED_OUT
  RETURNED
  CANCELLED
  DAMAGED
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

model EventDelegate {
  id                 Int           @id @default(autoincrement())
  eventRequestId     Int
  eventRequest       EventRequest  @relation(fields: [eventRequestId], references: [id], onDelete: Cascade)
  
  delegateUserId     Int
  delegateUser       User          @relation("EventDelegates", fields: [delegateUserId], references: [id], onDelete: Cascade)
  
  role               DelegateRole  @default(MANAGER)
  permissions        String?       // JSON string of granular permissions
  
  delegatedAt        DateTime      @default(now())
  removedAt          DateTime?
  isActive           Boolean       @default(true)
  
  @@unique([eventRequestId, delegateUserId])
  @@index([eventRequestId])
  @@index([delegateUserId])
  @@map("EventDelegate")
}

model EventDelegateHistory {
  id                 Int           @id @default(autoincrement())
  eventRequestId     Int
  eventRequest       EventRequest  @relation(fields: [eventRequestId], references: [id], onDelete: Cascade)
  
  actionType         String        // ADDED, REMOVED, ROLE_CHANGED, PERMISSIONS_CHANGED
  delegateUserId     Int
  delegateName       String
  role               DelegateRole?
  performedBy        Int
  performedByUser    User          @relation("DelegateActionPerformedBy", fields: [performedBy], references: [id], onDelete: SetNull)
  
  reason             String?
  createdAt          DateTime      @default(now())
  
  @@index([eventRequestId])
  @@index([createdAt])
  @@map("EventDelegateHistory")
}

enum MerchandiseProductStatus {
  IN_STOCK
  LOW_STOCK
  OUT_OF_STOCK
  ARCHIVED
}

enum MerchandiseOrderStatus {
  PENDING
  PAID
  COLLECTED
  CANCELLED
}
enum ReactionType {
  LIKE
  LOVE
  WOW
  FUNNY
  SAD
}

enum EventRequestStatus {
  PENDING
  APPROVED
  REJECTED
  REVISION_REQUESTED
  PUBLISHED
}
