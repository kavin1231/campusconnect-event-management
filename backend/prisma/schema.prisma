// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Student {
  id            Int                   @id @default(autoincrement())
  name          String
  email         String                @unique
  password      String
  studentId     String                @unique
  department    String
  year          Int
  profileImage  String?
  createdAt     DateTime              @default(now())
  registrations StudentEventRegistration[]
  presidentApplications PresidentApplication[]
  notifications StudentNotification[]
  eventReviews  EventReview[]

  @@map("Student")
}

model StudentEventRegistration {
  id         Int      @id @default(autoincrement())
  studentId  Int
  eventId    Int
  registeredAt DateTime @default(now())
  student    Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  event      Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([studentId, eventId])
  @@map("StudentRegistration")
}

enum Role {
  STUDENT
  EVENT_ORGANIZER
  SYSTEM_ADMIN
  CLUB_PRESIDENT
}

enum ClubStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  ARCHIVED
}

enum ClubRole {
  PRESIDENT
  VICE_PRESIDENT
  TREASURER
  MEMBER
}

enum AssetStatus {
  AVAILABLE
  UNAVAILABLE
  MAINTENANCE
  DAMAGED
  ARCHIVED
}

enum AssetCondition {
  EXCELLENT
  GOOD
  FAIR
  POOR
  DAMAGED
}

enum AssetCategory {
  EQUIPMENT
  FURNITURE
  TECHNOLOGY
  SPORTS
  SOUND_SYSTEM
  DECORATION
  VEHICLES
  OTHER
}

enum BookingStatus {
  PENDING
  APPROVED
  REJECTED
  CHECKED_OUT
  RETURNED
  CANCELLED
  DAMAGED
}

enum DamageType {
  PHYSICAL
  MECHANICAL
  ELECTRONIC
  STRUCTURAL
  OTHER
}

enum DamageSeverity {
  MINOR
  MODERATE
  MAJOR
  CRITICAL
}

enum DamageStatus {
  PENDING
  APPROVED
  REJECTED
  RESOLVED
  IN_PROGRESS
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum MerchandiseProductStatus {
  IN_STOCK
  LOW_STOCK
  OUT_OF_STOCK
  DISCONTINUED
}

enum MerchandiseOrderStatus {
  PENDING
  PAID
  PROCESSING
  READY_FOR_PICKUP
  COLLECTED
  CANCELLED
}

enum DelegateRole {
  CO_ORGANIZER
  MANAGER
  LOGISTICS
  FINANCES
}

model User {
  id               Int      @id @default(autoincrement())
  name             String
  email            String   @unique
  password         String
  role             Role
  profileImage     String?

  clubOrFacultyName String?
  clubOrFacultyType String?
  
  // Club relations  
  clubId           Int?
  club             Club?    @relation("ClubMembers", fields: [clubId], references: [id], onDelete: SetNull)
  clubRole         ClubRole?
  presidingClub    Club?    @relation("ClubPresident")
  
  // relationships for logistics module
  approvedBookings AssetBooking[]   @relation("AssetBookingApprovedBy")
  requestedBookings AssetBooking[]  @relation("AssetBookingRequester")
  approvedReturns  AssetBooking[]   @relation("ReturnApprovedBy")
  damageReports    DamageReport[]
  damageApprovals  DamageReport[]   @relation("DamageApprovedBy")
  
  approvedApplications PresidentApplication[]
  notifications    UserNotification[]

  // relations for study support
  studyMaterials   StudyMaterial[]  @relation("StudyMaterialCreator")
  studySessions    StudySession[]   @relation("StudySessionCreator")
  
  // relations for event requests
  eventRequestsSubmitted EventRequest[] @relation("EventRequestSubmitter")
  eventRequestsReviewed EventRequest[]  @relation("EventRequestReviewer")
  
  // relations for delegates
  delegates         EventDelegate[]  @relation("EventDelegates")
  delegateActions   EventDelegateHistory[] @relation("DelegateActionPerformedBy")
  
  // relations for events
  eventsSubmitted  Event[]          @relation("EventSubmitter")
  eventsApproved   Event[]          @relation("EventApprover")
  
  createdAt        DateTime @default(now())

  @@map("User")
}

model Event {
  id                Int                       @id @default(autoincrement())
  title             String
  description       String
  date              DateTime
  category          String
  location          String
  image             String
  registeredCount   Int                       @default(0)
  
  // Event workflow & status
  status            String?                   // DRAFT, APPROVED, PUBLISHED
  organizer         String?                   // Organizer name (Club/Faculty)
  organizerType     String?                   // CLUB or FACULTY
  organizerId       String?                   // Club/Faculty ID
  
  // Event details
  venue             String?
  budget            Float?                    // Estimated budget
  expectedAttendees Int?                      // Expected attendance
  
  // Submission & approval workflow
  submittedBy       Int?
  submitter         User?                     @relation("EventSubmitter", fields: [submittedBy], references: [id], onDelete: SetNull)
  submittedDate     DateTime?
  
  approvedBy        Int?
  approver          User?                     @relation("EventApprover", fields: [approvedBy], references: [id], onDelete: SetNull)
  approvedAt        DateTime?
  rejectionReason   String?
  
  // Relationships
  registrations     StudentEventRegistration[]
  reviews           EventReview[]
  
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @default(now()) @updatedAt

  @@index([status])
  @@index([date])
  @@map("Event")
}

// ========== EVENT REQUEST WORKFLOW ==========
model EventRequest {
  id                    Int       @id @default(autoincrement())
  
  // Basic Event Information
  title                 String
  eventType             String    // "Conference", "Workshop", "Seminar", etc.
  eventTypeOther        String?
  purposeTag            String    // "Educational", "Social", "Cultural", etc.
  purposeDescription    String    // Event description/purpose
  eventDate             DateTime
  startTime             String    // "09:00" format
  endTime               String    // "17:00" format
  setupTime             String?   // "08:00" format
  teardownTime          String?   // "18:00" format
  audience              String    // "University-Wide (Staff + Students)", etc.
  
  // Organizer Details
  organizingBody        String    // Club or Faculty name
  contactName           String
  contactId             String    // Normalized ID
  contactPhone          String
  contactEmail          String?
  supervisorName        String?
  supervisorDepartment  String?
  supervisorPhone       String?
  
  // Venue & Logistics
  venue                 String
  expectedAttendance    Int?
  seatingArrangement    String?   // "Theater Style", "Classroom", etc.
  parkingRequired       Boolean   @default(false)
  
  // Budget & Sponsorship
  estimatedBudget       Float?
  budgetBreakdown       String?
  sponsorshipDetails    String?
  fundSource            String?
  
  // Risk & Safety Assessment
  riskAssessment        String?
  safetyMeasures        String?
  emergencyPlan         String?
  contingency           String?
  
  // Event Setup (Tickets & Merchandise)
  bannerUrl             String?
  tickets               Json?     // Array of {name, price, inventory, enabled}
  merchandise           Json?     // Array of {name, description, price, inventory, imageUrl, enabled}
  pickupSlots           Json?     // Array of {label, date, startTime, endTime, location}
  
  // Workflow Status
  status                String    @default("DRAFT")  // DRAFT, SUBMITTED, PENDING, APPROVED, REJECTED, REVISION_REQUESTED, PUBLISHED
  submittedAt           DateTime?
  submittedBy           Int       // User who submitted
  submitter             User      @relation("EventRequestSubmitter", fields: [submittedBy], references: [id], onDelete: Cascade)
  
  reviewedAt            DateTime?
  reviewedBy            Int?      // Admin who reviewed
  reviewer              User?     @relation("EventRequestReviewer", fields: [reviewedBy], references: [id], onDelete: SetNull)
  reviewNotes           String?
  
  // Delegate Management
  delegates             EventDelegate[]  
  delegateHistory       EventDelegateHistory[]
  
  // Merchandise scoping
  merchandiseProducts   MerchandiseProduct[]
  merchandiseOrders     MerchandiseOrder[]
  
  // Audit Trail
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  
  @@index([status])
  @@index([eventDate])
  @@index([submittedBy])
  @@index([venue])
  @@map("EventRequest")
}

// ========== CLUB MANAGEMENT ==========
model Club {
  id                Int                @id @default(autoincrement())
  name              String             @unique
  description       String?
  clubType          String             // "ACADEMIC", "SOCIAL", "SPORTS", "CULTURAL"
  logo              String?            // Image URL
  members           User[]             @relation("ClubMembers")
  president         User?              @relation("ClubPresident", fields: [presidentId], references: [id])
  presidentId       Int?               @unique
  status            ClubStatus         @default(ACTIVE)
  
  // Assets and logistics
  assets            Asset[]            @relation("ClubAssets")
  requestsSent      AssetBooking[]     @relation("RequestingClub")
  requestsReceived  AssetBooking[]     @relation("OwningClub")
  damageReports     DamageReport[]
  
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@index([status])
  @@map("Club")
}

// ========== ENHANCED LOGISTICS MODELS ==========
model Asset {
  id               Int                 @id @default(autoincrement())
  name             String
  description      String?
  category         AssetCategory?      // Made optional for data compatibility
  quantity         Int                 @default(1)
  availableQty     Int                 @default(1)
  condition        AssetCondition      @default(GOOD)
  
  // Owner club
  clubId           Int?                // Made optional for data compatibility
  club             Club?               @relation(name: "ClubAssets", fields: [clubId], references: [id], onDelete: Cascade)
  
  // Images
  images           String[]            // Array of image URLs
  thumbnail        String?
  
  // Metadata
  value            Float?              // Asset value for insurance
  status           AssetStatus         @default(AVAILABLE)
  
  // Relationships
  bookings         AssetBooking[]
  damageReports    DamageReport[]
  
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @default(now()) @updatedAt

  @@index([clubId])
  @@index([status])
  @@index([category])
  @@map("Asset")
}

model AssetBooking {
  id                  Int                @id @default(autoincrement())
  assetId             Int
  asset               Asset              @relation(fields: [assetId], references: [id], onDelete: Cascade)
  
  // Requesting club details
  requestingClubId    Int
  requestingClub      Club               @relation(name: "RequestingClub", fields: [requestingClubId], references: [id], onDelete: Cascade)
  
  // Asset owner club
  owningClubId        Int
  owningClub          Club               @relation(name: "OwningClub", fields: [owningClubId], references: [id], onDelete: Cascade)
  
  // User who requested
  requesterId         Int
  requester           User               @relation(name: "AssetBookingRequester", fields: [requesterId], references: [id])
  
  // Booking details
  quantityRequested   Int                @default(1)
  startDate           DateTime
  endDate             DateTime
  purpose             String?
  
  // Approval
  status              BookingStatus      @default(PENDING)
  approvedById        Int?
  approvedBy          User?              @relation(name: "AssetBookingApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)
  approvedAt          DateTime?
  rejectionReason     String?
  
  // Return tracking
  checkedOutAt        DateTime?
  returnedAt          DateTime?
  approvedReturnBy    Int?
  approvedReturnUser  User?              @relation(name: "ReturnApprovedBy", fields: [approvedReturnBy], references: [id], onDelete: SetNull)
  
  // Damage & penalties
  damageReport        DamageReport?
  penalty             Float?             @default(0)
  
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  @@unique([assetId, requestingClubId, startDate, endDate])
  @@index([assetId])
  @@index([requestingClubId])
  @@index([owningClubId])
  @@index([requesterId])
  @@index([status])
  @@map("AssetBooking")
}

model DamageReport {
  id              Int                @id @default(autoincrement())
  bookingId       Int?               @unique
  booking         AssetBooking?      @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  
  assetId         Int
  asset           Asset              @relation(fields: [assetId], references: [id], onDelete: Cascade)
  
  clubId          Int
  club            Club               @relation(fields: [clubId], references: [id], onDelete: Cascade)
  
  reportedBy      Int
  reporter        User               @relation(fields: [reportedBy], references: [id])
  
  title           String
  description     String
  damageType      DamageType
  severity        DamageSeverity
  
  images          String[]           // Damage photos
  estimatedCost   Float?
  actualCost      Float?
  
  status          DamageStatus       @default(PENDING)
  approvedById    Int?
  approvedBy      User?              @relation(name: "DamageApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)
  
  penalty         Float?
  resolutionNotes String?
  
  createdAt       DateTime           @default(now())
  resolvedAt      DateTime?

  @@index([assetId])
  @@index([clubId])
  @@index([status])
  @@map("DamageReport")
}

// president applications
model PresidentApplication {
  id                    Int                @id @default(autoincrement())
  studentId             Int
  student               Student            @relation(fields: [studentId], references: [id], onDelete: Cascade)
  presidentName         String             // The name to use for president account
  candidateId           String             // President ID/candidate ID
  clubOrFacultyType     String             // "CLUB" or "FACULTY"
  clubOrFacultyName     String             // Name of club or faculty
  currentQualification  String             // Current qualification/position
  email                 String             // email for president account
  status                ApplicationStatus  @default(PENDING)
  rejectionReason       String?            // Reason for rejection if rejected
  appliedAt             DateTime           @default(now())
  approvedRejectAt      DateTime?          // When it was approved/rejected
  approvedById          Int?
  approvedBy            User?              @relation(fields: [approvedById], references: [id], onDelete: SetNull)
}

// Student notifications/alerts
model StudentNotification {
  id        Int       @id @default(autoincrement())
  studentId Int
  student   Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  type      String    // "PRESIDENT_APPROVED", "PRESIDENT_REJECTED", "PASSWORD_ALERT", etc.
  title     String
  message   String
  data      String?   // JSON string for additional data (e.g., password)
  isRead    Boolean   @default(false)
  createdAt DateTime  @default(now())

  @@index([studentId])
  @@index([createdAt])
}

// User notifications (for admin/president accounts)
model UserNotification {
  id        Int       @id @default(autoincrement())
  userId    Int
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String    // "APPLICATION_CREATED", "NEW_REQUEST", etc.
  title     String
  message   String
  data      String?   // JSON string for additional data
  isRead    Boolean   @default(false)
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([createdAt])
}

// Study Support and Materials
model StudyMaterial {
  id            Int       @id @default(autoincrement())
  semester      String    // Y1S1, Y1S2, Y2S1, Y2S2, Y3S1, Y3S2, Y4S1, Y4S2
  title         String
  description   String?
  materialType  String    // pdf, link, video, other
  contentUrl    String    // URL for links or PDF download
  uploadedAt    DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  createdBy     Int       // Admin ID
  creator       User      @relation(name: "StudyMaterialCreator", fields: [createdBy], references: [id])
}

model StudySession {
  id            Int       @id @default(autoincrement())
  semester      String    // Y1S1, Y1S2, Y2S1, Y2S2, Y3S1, Y3S2, Y4S1, Y4S2
  title         String
  description   String
  sessionDate   DateTime
  sessionLink   String?   // Zoom/Meet link
  sessionNotes  String?   // Additional notes
  uploadedAt    DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  createdBy     Int       // Admin ID
  creator       User      @relation(name: "StudySessionCreator", fields: [createdBy], references: [id])
}

// Reaction Enum for Events
enum ReactionType {
  LIKE
  LOVE
  WOW
  FUNNY
  SAD
}

// Event Reviews with Reactions
model EventReview {
  id        Int           @id @default(autoincrement())
  eventId   Int
  studentId Int
  reaction  ReactionType?  // 👍 Like, ❤️ Love, 😮 Wow, 😂 Funny, 😢 Sad
  comment   String?        // User comment
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  
  event     Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  student   Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, eventId])
  @@index([eventId])
  @@map("EventReview")
}

// ========== MERCHANDISE ==========
model MerchandiseProduct {
  id          Int                    @id @default(autoincrement())
  name        String
  description String?
  price       Float                  @default(0)
  imageUrl    String?
  status      MerchandiseProductStatus @default(IN_STOCK)
  inventory   Int                    @default(0)
  isActive    Boolean                @default(true)
  
  eventRequestId Int?
  eventRequest   EventRequest?       @relation(fields: [eventRequestId], references: [id], onDelete: SetNull)
  
  orderItems  MerchandiseOrderItem[]
  
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt

  @@index([status])
  @@map("MerchandiseProduct")
}

model MerchandiseOrder {
  id              Int                    @id @default(autoincrement())
  buyerId         Int?
  buyerName       String
  buyerEmail      String?
  buyerPhone      String?
  studentNumber   String?
  totalAmount     Float                  @default(0)
  status          MerchandiseOrderStatus @default(PENDING)
  notes           String?
  paymentSlipUrl  String?
  
  eventRequestId  Int?
  eventRequest    EventRequest?          @relation(fields: [eventRequestId], references: [id], onDelete: SetNull)
  
  items           MerchandiseOrderItem[]
  
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  @@index([status])
  @@index([buyerId])
  @@map("MerchandiseOrder")
}

model MerchandiseOrderItem {
  id        Int                @id @default(autoincrement())
  orderId   Int
  order     MerchandiseOrder   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  productId Int
  product   MerchandiseProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  quantity  Int                @default(1)
  unitPrice Float              @default(0)
  size      String?
  
  createdAt DateTime           @default(now())

  @@index([orderId])
  @@index([productId])
  @@map("MerchandiseOrderItem")
}

// ========== DELEGATE MANAGEMENT ==========
model EventDelegate {
  id                 Int           @id @default(autoincrement())
  eventRequestId     Int
  eventRequest       EventRequest  @relation(fields: [eventRequestId], references: [id], onDelete: Cascade)
  
  delegateUserId     Int
  delegateUser       User          @relation("EventDelegates", fields: [delegateUserId], references: [id], onDelete: Cascade)
  
  role               DelegateRole  @default(MANAGER)
  permissions        String?       // JSON string of granular permissions
  
  delegatedAt        DateTime      @default(now())
  removedAt          DateTime?
  isActive           Boolean       @default(true)
  
  @@unique([eventRequestId, delegateUserId])
  @@index([eventRequestId])
  @@index([delegateUserId])
  @@map("EventDelegate")
}

model EventDelegateHistory {
  id                 Int           @id @default(autoincrement())
  eventRequestId     Int
  eventRequest       EventRequest  @relation(fields: [eventRequestId], references: [id], onDelete: Cascade)
  
  actionType         String        // ADDED, REMOVED, ROLE_CHANGED, PERMISSIONS_CHANGED
  delegateUserId     Int
  delegateName       String
  role               DelegateRole?
  performedBy        Int
  performedByUser    User          @relation("DelegateActionPerformedBy", fields: [performedBy], references: [id], onDelete: SetNull)
  
  reason             String?
  createdAt          DateTime      @default(now())
  
  @@index([eventRequestId])
  @@index([createdAt])
  @@map("EventDelegateHistory")
}
